<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Frank's Toolset" Height="600" Width="680"
    WindowStyle="None" AllowsTransparency="True" Background="Transparent"
    WindowStartupLocation="CenterScreen">

    <Window.Resource>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                Background="Transparent"
                                BorderBrush="#FF9A2E"
                                BorderThickness="1"
                                Padding="4">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF9A2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#C0C0C0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Flashing star storyboard -->
        <Storyboard x:Key="starFlash">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.15" To="0.9"
                             Duration="0:0:1.4"
                             AutoReverse="True"
                             RepeatBehavior="Forever"/>
        </Storyboard>
        <Storyboard x:Key="starDrift">
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.X"
                             From="0" To="4"
                             Duration="0:0:2.2"
                             AutoReverse="True"
                             RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Y"
                             From="0" To="4"
                             Duration="0:0:2.2"
                             AutoReverse="True"
                             RepeatBehavior="Forever"/>
        </Storyboard>
        <Style x:Key="Star" TargetType="Ellipse">
            <Setter Property="Fill" Value="White"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Setter Property="RenderTransform"><Setter.Value><TranslateTransform/></Setter.Value></Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Ellipse.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource starFlash}"/>
                    <BeginStoryboard Storyboard="{StaticResource starDrift}"/>
                </EventTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!-- Outer border with glow -->
    <Border CornerRadius="18" BorderThickness="1.5" BorderBrush="#FF9A2E">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#181818" Offset="0"/>
                <GradientStop Color="#222222" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#FF9A2E" ShadowDepth="0" BlurRadius="20" Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- STARS (behind content) -->
            <Canvas Grid.Row="1" IsHitTestVisible="False">
                <Ellipse Style="{StaticResource Star}" Width="2" Height="2"  Canvas.Left="20"  Canvas.Top="40"/>
                <Ellipse Style="{StaticResource Star}" Width="3" Height="3"  Canvas.Left="55"  Canvas.Top="120"/>
                <Ellipse Style="{StaticResource Star}" Width="2" Height="2"  Canvas.Left="15"  Canvas.Top="220"/>
                <Ellipse Style="{StaticResource Star}" Width="3" Height="3"  Canvas.Left="45"  Canvas.Top="340"/>
                <Ellipse Style="{StaticResource Star}" Width="2" Height="2"  Canvas.Left="70"  Canvas.Top="430"/>
                <Ellipse Style="{StaticResource Star}" Width="3" Height="3"  Canvas.Left="220" Canvas.Top="20"/>
                <Ellipse Style="{StaticResource Star}" Width="2" Height="2"  Canvas.Left="380" Canvas.Top="35"/>
                <Ellipse Style="{StaticResource Star}" Width="3" Height="3"  Canvas.Left="500" Canvas.Top="60"/>
                <Ellipse Style="{StaticResource Star}" Width="2" Height="2"  Canvas.Left="600" Canvas.Top="30"/>
                <Ellipse Style="{StaticResource Star}" Width="3" Height="3"  Canvas.Left="610" Canvas.Top="180"/>
                <Ellipse Style="{StaticResource Star}" Width="2" Height="2"  Canvas.Left="580" Canvas.Top="340"/>
                <Ellipse Style="{StaticResource Star}" Width="3" Height="3"  Canvas.Left="540" Canvas.Top="440"/>
                <Ellipse Style="{StaticResource Star}" Width="2" Height="2"  Canvas.Left="300" Canvas.Top="460"/>
                <Ellipse Style="{StaticResource Star}" Width="3" Height="3"  Canvas.Left="140" Canvas.Top="420"/>
                <Ellipse Style="{StaticResource Star}" Width="2" Height="2"  Canvas.Left="430" Canvas.Top="270"/>
                <Ellipse Style="{StaticResource Star}" Width="2" Height="2"  Canvas.Left="310" Canvas.Top="130"/>
            </Canvas>

            <!-- HEADER -->
            <Grid MouseDown="header_drag" Background="Transparent" Grid.Row="0" Margin="16,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                    <!-- "F" Badge -->
                    <Border Width="30" Height="30" CornerRadius="7" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF9A2E" Offset="0"/>
                                <GradientStop Color="#CC6E15" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="F" FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    </Border>
                    <TextBlock Text="Frank's Toolset" FontSize="14" FontWeight="SemiBold"
                               Foreground="#DDDDDD" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="✕" Grid.Column="1"
                        Width="30" Height="30" FontSize="13"
                        Click="button_close"
                        VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Header separator -->
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Margin="16,0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#FF9A2E" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- MAIN CONTENT -->
            <StackPanel Grid.Row="1" Margin="32,24,32,20">

                <!-- Hero -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,22">

                    <!-- Monogram with glow -->
                    <Border x:Name="Monogram" Width="72" Height="72" CornerRadius="18"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF9A2E" Offset="0"/>
                                <GradientStop Color="#CC6E15" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect x:Name="MonogramGlow"
                                              Color="#FF9A2E" ShadowDepth="0"
                                              BlurRadius="28" Opacity="0.7"/>
                        </Border.Effect>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Border.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="MonogramGlow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            From="16" To="40"
                                            Duration="0:0:1.8" AutoReverse="True"/>
                                        <DoubleAnimation
                                            Storyboard.TargetName="MonogramGlow"
                                            Storyboard.TargetProperty="Opacity"
                                            From="0.5" To="0.9"
                                            Duration="0:0:1.8" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <TextBlock Text="F" FontSize="40" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    </Border>

                    <TextBlock Text="Welcome to Frank's Toolset"
                               FontSize="24" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Custom Revit automation — built fast, built right."
                               FontSize="13" Foreground="#666666"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- Divider -->
                <Rectangle Height="1" Margin="0,0,0,20">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#2E2E2E" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Feature cards — row 1 -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#202020" CornerRadius="12" Padding="16,14">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" ShadowDepth="1" BlurRadius="10" Opacity="0.5"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="⚡" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="Automation" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#FF9A2E" Margin="0,0,0,4"/>
                            <TextBlock Text="Eliminate repetitive tasks with scripts that just work."
                                       FontSize="11" Foreground="#606060"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#202020" CornerRadius="12" Padding="16,14">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" ShadowDepth="1" BlurRadius="10" Opacity="0.5"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🎯" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="Precision" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#FF9A2E" Margin="0,0,0,4"/>
                            <TextBlock Text="Purpose-built for accuracy — the right result every time."
                                       FontSize="11" Foreground="#606060"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Feature cards — row 2 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#202020" CornerRadius="12" Padding="16,14">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" ShadowDepth="1" BlurRadius="10" Opacity="0.5"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🏗️" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="BIM Native" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#FF9A2E" Margin="0,0,0,4"/>
                            <TextBlock Text="Lives inside Revit, speaks Revit, integrates seamlessly."
                                       FontSize="11" Foreground="#606060"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#202020" CornerRadius="12" Padding="16,14">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" ShadowDepth="1" BlurRadius="10" Opacity="0.5"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🔧" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="Firm Specific" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#FF9A2E" Margin="0,0,0,4"/>
                            <TextBlock Text="Tailored to BBB Architects' standards and projects."
                                       FontSize="11" Foreground="#606060"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Getting started callout -->
                <Border CornerRadius="12" Padding="18,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1E1E1E" Offset="0"/>
                            <GradientStop Color="#202020" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF9A2E" Offset="0"/>
                            <GradientStop Color="#333333" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,7">
                            <Run Text="🚀  Getting Started"/>
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="#606060">
                            <Run Text="Browse the "/>
                            <Run Text="FRANK" FontWeight="Bold" Foreground="#FF9A2E"/>
                            <Run Text=" tab above — each panel groups related tools. Hover any button for a quick description."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- FOOTER -->
            <TextBlock Grid.Row="2"
                       Text="Frank's Toolset  ·  v1.0  ·  BBB Architects"
                       FontSize="11" Foreground="#363636"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

        </Grid>
    </Border>
</Window>
